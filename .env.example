# Application
ENVIRONMENT=development
LOG_LEVEL=INFO
APP_NAME=Insight API
APP_VERSION=1.0.0

# Database (asyncpg only — do NOT use psycopg2)
# Local:
DATABASE_URL=postgresql+asyncpg://insight:insight@localhost:5432/insight
# Neon production example:
# DATABASE_URL=postgresql+asyncpg://user:password@ep-xxx.neon.tech/neondb?sslmode=require

# Security
SECRET_KEY=change-me-to-a-long-random-string-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_HOURS=2

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Admin (used by create_admin.py and seed)
ADMIN_EMAIL=admin@insight.dev
ADMIN_PASSWORD=changeme123!

# Analytics limits
MAX_ANALYTICS_RANGE_DAYS=365
MAX_BATCH_EVENTS=100
MAX_EVENT_PROPERTIES_SIZE_KB=10
